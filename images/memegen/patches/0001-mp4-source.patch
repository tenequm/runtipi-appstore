+def decode_mp4(path: Path) -> tuple[list[ImageType], int, int]:
+    """Decode an MP4 into RGB frames + per-frame duration (ms) + frame count.
+
+    Pillow can't read MP4, so both static (first-frame) and animated rendering
+    route video sources through PyAV (its wheels bundle ffmpeg)."""
+    with av.open(str(path)) as container:
+        stream = container.streams.video[0]
+        rate = float(stream.average_rate) if stream.average_rate else 25.0
+        frames = [frame.to_image() for frame in container.decode(stream)]
+    duration = round(1000 / rate) if rate else 100
+    return frames, duration, len(frames)
+
+
+def save_mp4(frames: list[ImageType], path: str, fps: int) -> None:
+    """Encode frames to a social-friendly H.264 MP4 (yuv420p, +faststart, no audio)."""
+    w, h = frames[0].size
+    w -= w % 2  # H.264 yuv420p needs even dimensions
+    h -= h % 2
+    with av.open(path, mode="w", options={"movflags": "+faststart"}) as container:
+        stream = container.add_stream("libx264", rate=fps)
+        stream.width, stream.height = w, h
+        stream.pix_fmt = "yuv420p"
+        stream.options = {"crf": "23"}
+        for img in frames:
+            frame = av.VideoFrame.from_image(img.convert("RGB").resize((w, h)))
+            container.mux(stream.encode(frame))
+        container.mux(stream.encode())
+
+
